REFRESH_TOKEN_TTL_DAYS=30
REFRESH_COOKIE_NAME=datcuatoi_refresh
LOG_LEVEL=info
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=datcuatoi-media
