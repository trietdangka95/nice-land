REFRESH_TOKEN_TTL_DAYS=30
REFRESH_COOKIE_NAME=nice_land_refresh
LOG_LEVEL=info
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=nice-land-media
AWS_S3_PUBLIC_URL=https://cdn.nice-land.vn
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
