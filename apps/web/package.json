{
  "name": "@nice-land/web",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "corepack pnpm --filter @nice-land/contracts build && corepack pnpm --filter @nice-land/api-client build && next build",
    "start": "next start -p 3002",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@nice-land/api-client": "workspace:*",
    "@nice-land/contracts": "workspace:*",
    "lucide-react": "^0.468.0",
    "next": "^16.2.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
