generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  GUEST
}

enum PropertyType {
  LAND
  HOUSE
  APARTMENT
  RENTAL
}

enum PostStatus {
  DRAFT
  PUBLISHED
  HIDDEN
  SOLD
  ARCHIVED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  GRACE_PERIOD
  EXPIRED
  SUSPENDED
}

enum DomainStatus {
  PENDING
  VERIFIED
  FAILED
}

enum RequestStatus {
  NEW
  IN_PROGRESS
  APPROVED
  REJECTED
  DONE
}

enum PublicTheme {
  CLASSIC_ESTATE
  MODERN_GRID
  EDITORIAL
  WARM_MINIMAL
}

model Site {
  id                 String                 @id @default(uuid())
  name               String
  slug               String                 @unique
  tagline            String?
  logo               String?
  banner             String?
  themeKey           PublicTheme            @default(CLASSIC_ESTATE)
  themeColor         String?
  phone              String?
  email              String?
  address            String?
  facebookUrl        String?
  zaloPhone          String?
  isActive           Boolean                @default(true)
  subscriptionStatus SubscriptionStatus     @default(TRIAL)
  subscriptionStart  DateTime?
  subscriptionEnd    DateTime?
  planId             String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  deletedAt          DateTime?
  users              User[]
  posts              PropertyPost[]
  categories         PropertyCategory[]
  auditLogs          AuditLog[]
  domains            SiteDomain[]
  refreshSessions    RefreshSession[]
  renewalRequests    RenewalRequest[]
  subscriptionHistory SubscriptionHistory[]
  leads              Lead[]
  propertyViews      PropertyView[]
  contactRequests    ContactRequest[]
  plan               SubscriptionPlan?      @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([isActive, subscriptionStatus])
  @@index([planId])
  @@index([deletedAt])
}

model SiteDomain {
  id           String       @id @default(uuid())
  siteId       String
  hostname     String       @unique
  isPrimary    Boolean      @default(false)
  isPlatform   Boolean      @default(false)
  status       DomainStatus @default(PENDING)
  verificationToken String?
  verifiedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  site         Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, status])
}

model User {
  id                  String               @id @default(uuid())
  siteId              String?
  username            String
  email               String?              @unique
  passwordHash        String
  fullName            String?
  phone               String?
  role                UserRole
  isActive            Boolean              @default(true)
  lastLoginAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?
  site                Site?                @relation(fields: [siteId], references: [id], onDelete: Cascade)
  refreshSessions     RefreshSession[]
  passwordResetTokens PasswordResetToken[]
  createdPosts        PropertyPost[]       @relation("PostCreatedBy")
  updatedPosts        PropertyPost[]       @relation("PostUpdatedBy")
  auditLogs           AuditLog[]
  renewalRequests     RenewalRequest[]     @relation("RenewalRequestedBy")

  @@unique([username, siteId])
  @@index([siteId, role, isActive])
  @@index([deletedAt])
}

model RefreshSession {
  id              String   @id @default(uuid())
  userId          String
  siteId          String?
  tokenHash       String   @unique
  userAgent       String?
  ipAddress       String?
  expiresAt       DateTime
  lastUsedAt      DateTime?
  revokedAt       DateTime?
  replacedById    String?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  site            Site?    @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([siteId, revokedAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PropertyCategory {
  id        String         @id @default(uuid())
  siteId    String
  name      String
  slug      String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  deletedAt DateTime?
  site      Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  posts     PropertyPost[]

  @@unique([siteId, slug])
  @@index([siteId, deletedAt])
}

model PropertyPost {
  id          String            @id @default(uuid())
  siteId      String
  categoryId  String?
  slug        String
  title       String
  description String
  type        PropertyType
  price       Decimal?          @db.Decimal(18, 2)
  area        Float?
  address     String?
  province    String?
  district    String?
  ward        String?
  latitude    Float?
  longitude   Float?
  legalStatus String?
  bedrooms    Int?
  bathrooms   Int?
  status      PostStatus        @default(DRAFT)
  publishedAt DateTime?
  createdById String?
  updatedById String?
  version     Int               @default(1)
  viewCount   Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?
  site        Site              @relation(fields: [siteId], references: [id], onDelete: Cascade)
  category    PropertyCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy   User?             @relation("PostCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?             @relation("PostUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  images      PropertyImage[]
  views       PropertyView[]
  leads       Lead[]

  @@unique([siteId, slug])
  @@index([siteId, status, publishedAt])
  @@index([siteId, type, price])
  @@index([siteId, province, district])
  @@index([siteId, deletedAt])
}

model PropertyImage {
  id         String       @id @default(uuid())
  postId     String
  storageKey String       @unique
  url        String
  mimeType   String?
  size       Int?
  width      Int?
  height     Int?
  altText    String?
  sortOrder  Int          @default(0)
  createdAt  DateTime     @default(now())
  post       PropertyPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, sortOrder])
}

model PropertyView {
  id         String       @id @default(uuid())
  postId     String
  siteId     String
  visitorHash String?
  referrer   String?
  userAgent  String?
  viewedAt   DateTime     @default(now())
  post       PropertyPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  site       Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, viewedAt])
  @@index([postId, viewedAt])
}

model Lead {
  id         String        @id @default(uuid())
  siteId     String
  postId     String?
  name       String
  phone      String
  email      String?
  message    String?
  source     String?
  status     RequestStatus @default(NEW)
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  site       Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  post       PropertyPost? @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([siteId, status, createdAt])
  @@index([postId])
}

model SubscriptionPlan {
  id               String   @id @default(uuid())
  name             String   @unique
  code             String   @unique
  maxPosts         Int
  maxImagesPerPost Int
  price            Decimal  @db.Decimal(18, 2)
  durationDays     Int
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  sites            Site[]
  renewalRequests  RenewalRequest[]
  history          SubscriptionHistory[]
}

model RenewalRequest {
  id            String        @id @default(uuid())
  siteId        String
  planId        String?
  requestedById String
  status        RequestStatus @default(NEW)
  note          String?
  adminNote     String?
  requestedAt   DateTime      @default(now())
  resolvedAt    DateTime?
  site          Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  plan          SubscriptionPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  requestedBy   User          @relation("RenewalRequestedBy", fields: [requestedById], references: [id], onDelete: Restrict)

  @@index([siteId, status, requestedAt])
}

model SubscriptionHistory {
  id          String             @id @default(uuid())
  siteId      String
  planId      String?
  status      SubscriptionStatus
  startsAt    DateTime
  endsAt      DateTime?
  amount      Decimal?           @db.Decimal(18, 2)
  note        String?
  createdAt   DateTime           @default(now())
  site        Site               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  plan        SubscriptionPlan?  @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([siteId, createdAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  siteId    String?
  userId    String?
  action    String
  entityType String?
  entityId  String?
  details   Json?
  ipAddress String?
  userAgent String?
  requestId String?
  createdAt DateTime @default(now())
  site      Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([siteId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model ContactRequest {
  id        String        @id @default(uuid())
  siteId    String?
  name      String
  phone     String
  email     String?
  message   String?
  status    RequestStatus @default(NEW)
  source    String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  site      Site?         @relation(fields: [siteId], references: [id], onDelete: SetNull)

  @@index([siteId, status, createdAt])
  @@index([createdAt])
}
